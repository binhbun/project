
#import <Foundation/Foundation.h>
#import <objc/runtime.h>

static id (*original_JSONObjectWithData)(Class self, SEL _cmd, NSData *data, NSJSONReadingOptions opt, NSError **error);

id hooked_JSONObjectWithData(Class self, SEL _cmd, NSData *data, NSJSONReadingOptions opt, NSError **error) {

    id result = original_JSONObjectWithData(self, _cmd, data, opt, error);
    
    if ([result isKindOfClass:[NSDictionary class]]) {
        NSMutableDictionary *dict = [result mutableCopy];
        
        if (dict[@"valid"] != nil && dict[@"msg"] != nil) {
     
            NSString *jsonString = [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];
            NSLog(@"[UniversalHook] Intercepted license response: %@", jsonString);
            
            dict[@"valid"] = @"true";
            dict[@"msg"] = @"License bypassed successfully";
            
            if (!dict[@"responseExpire"]) {
                NSDateFormatter *formatter = [[NSDateFormatter alloc] init];
                formatter.dateFormat = @"yyyy-MM-dd'T'HH:mm:ssZ";
                NSDate *future = [NSDate dateWithTimeIntervalSinceNow:86400];
                dict[@"responseExpire"] = [formatter stringFromDate:future];
            }
            
            NSLog(@"[UniversalHook] Modified license response to: %@", dict);
            return dict;
        }
    }
    
    return result;
}

static void injectLicenseDefaults() {
    NSUserDefaults *defaults = [NSUserDefaults standardUserDefaults];
    
    if ([defaults objectForKey:@"com.i3rby.8poolmod.license.expires_at"] == nil) {
        [defaults setObject:@"9999-01-01T00:00:00Z" forKey:@"com.i3rby.8poolmod.license.expires_at"];
        [defaults setObject:@"GMVMOBA-BINHBUN" forKey:@"com.i3rby.8poolmod.license.key"];
        [defaults setObject:@"HACK-VIP-BY-BINHBUN" forKey:@"com.i3rby.8poolmod.license.device"];
        [defaults setBool:YES forKey:@"com.i3rby.8poolmod.license.valid"];
        [defaults synchronize];
    }
}

__attribute__((constructor)) void hook_init() {
    injectLicenseDefaults();

    Class jsonClass = NSClassFromString(@"NSJSONSerialization");
    Method jsonMethod = class_getClassMethod(jsonClass, @selector(JSONObjectWithData:options:error:));
    if (jsonMethod) {
        original_JSONObjectWithData = (id (*)(Class, SEL, NSData*, NSJSONReadingOptions, NSError**))method_getImplementation(jsonMethod);
        method_setImplementation(jsonMethod, (IMP)hooked_JSONObjectWithData);
        NSLog(@"[UniversalHook] Successfully hooked NSJSONSerialization");
    }
}
